{
  // ── TPT Code Command Center — workspace settings ───────────────────────────
  // These are the default values shipped with the extension.
  // Override any value here to customise TPT behaviour for this workspace.

  // ── Upstream provider ─────────────────────────────────────────────────────
  // Options: "openrouter" | "anthropic" | "openai" | "local" | "custom"
  "tpt.upstreamProvider": "openrouter",
  // "tpt.openrouterApiKey": "",
  // "tpt.anthropicApiKey": "",
  // "tpt.openaiApiKey": "",

  // ── Cline / Roo-Code manual setup ─────────────────────────────────────────
  // TPT automatically injects ANTHROPIC_BASE_URL and OPENAI_BASE_URL into
  // every new integrated terminal on activation — Cline picks these up
  // without any manual configuration.
  //
  // If you need to point Cline at the proxy by hand:
  //   1. Cline sidebar → gear icon → API Provider → "OpenAI Compatible"
  //   2. Base URL: http://localhost:7331
  //   3. Add request header:
  //        X-TPT-Token: <run "TPT: Copy Proxy URL to Clipboard" to get token>
  //
  // Claude Code CLI:
  //   Open a new integrated terminal. TPT will have set ANTHROPIC_BASE_URL
  //   automatically, so Claude Code points at the proxy from that terminal.

  // ── Module toggles ─────────────────────────────────────────────────────────
  // "tpt.vault.enabled": true,
  // "tpt.smartContext.enabled": true,
  // "tpt.tokenShield.enabled": true,
  // "tpt.memoryWeaver.enabled": true,
  // "tpt.router.enabled": false,
  // "tpt.silentEdit.enabled": false,

  // ── Terminal env (auto-managed by TPT — shown here for reference only) ────
  // TPT writes these on activation; you do not need to set them manually.
